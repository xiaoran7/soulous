# =========================================================================
# Soulous agent-service 环境变量模板（复制为 .env 后填写）
# =========================================================================

# ---- LLM 提供商（openai / deepseek / mimo / mock）----
# mock：确定性回放，零 key 跑全链路，对齐 Soulous 的 SOULOUS_LLM_PROVIDER=mock 联调流
ACTIVE_PROVIDER=mock

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# ---- Embedding（独立于 LLM；留空时 RAG 检索返回空集，绝不降级为伪向量）----
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=768

# ---- 服务与安全 ----
AGENT_HOST=127.0.0.1
AGENT_PORT=8100
# Spring ⇄ agent 共享密钥：请求头 X-Service-Token 必须匹配；留空 = 仅限本地调试
AGENT_SERVICE_TOKEN=change-me

# Spring Boot 内部 API（工具回调 + guardrail fast-path）
SOULOUS_BASE_URL=http://127.0.0.1:8080
SOULOUS_SERVICE_TOKEN=change-me

# ---- 上下文预算（token，近似计数）----
BUDGET_SYSTEM_TOKENS=2000
BUDGET_CONVERSATION_TOKENS=2400
BUDGET_SCRATCH_TOKENS=2000

# ---- 数据目录（三个 sqlite 库落在这里）----
AGENT_DATA_DIR=data
